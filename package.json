{
  "name": "knotquite",
  "version": "1.0.0",
  "description": "A NYT Connections clone for desktop and mobile",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "generate:puzzles": "node scripts/generate_puzzles_llm.js",
    "generate:puzzles:3months": "node scripts/generate_puzzles_three_months.js",
    "validate:puzzles": "node scripts/validate_puzzles.js src/data/puzzles.json",
    "build:daily-order": "node scripts/build_daily_order.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.urlxl.knotquite",
    "productName": "KnotQuite",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}
